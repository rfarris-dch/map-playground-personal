# Production HTTP runtime.
# The first-pass EC2 deploy contract currently fixes the API listener to 3001.
NODE_ENV=production
PORT=3001

# Required database connection for PostGIS-backed API routes.
DATABASE_URL=postgres://app_user:replace-me@db-host:5432/map
# POSTGRES_URL=postgres://app_user:replace-me@db-host:5432/map

# This API build only supports the PostGIS production path for these datasets.
BOUNDARIES_SOURCE_MODE=postgis
FACILITIES_SOURCE_MODE=postgis
PARCELS_SOURCE_MODE=postgis

# Optional response metadata versioning for deploys.
API_DATA_VERSION=staging

# First-pass EC2 deployment keeps background automation disabled.
AUTO_PARCELS_SYNC=false

# Optional HTTP request tuning.
API_REQUEST_BODY_LIMIT_BYTES=1048576
API_REQUEST_TIMEOUT_MS=30000
API_SELECTION_REQUEST_TIMEOUT_MS=30000
API_PARCELS_REQUEST_TIMEOUT_MS=30000
EXPOSE_SYNC_INTERNALS=false

# Required for this first-pass EC2 deployment.
# The shipped web boot initializes FiberLocator during normal map startup, so these
# upstream settings are part of the live runtime contract for aws/app.
FIBER_LOCATOR_SOURCE_MODE=external-xyz
FIBERLOCATOR_API_BASE_URL=https://fiberlocator.example.com
FIBERLOCATOR_STATIC_TOKEN=replace-me
FIBERLOCATOR_LINE_IDS=metro,longhaul
FIBERLOCATOR_REQUEST_TIMEOUT_MS=15000
FIBERLOCATOR_TILE_CACHE_MAX_ENTRIES=200
FIBERLOCATOR_TILE_CACHE_TTL_MS=300000
