# Set external mode in deploy builds so Vite does not copy local PMTiles blobs into dist.
# In external mode, every tileset the app can load must have a manifest URL configured.
VITE_TILE_MANIFEST_MODE=external

# Required for aws/app deploy builds right now:
# - parcels
# Optional until revisited for this playground pass:
# - environmental flood
# - environmental hydro basins
#
# These should be the CloudFront HTTPS latest.json URLs for the published PMTiles
# manifests. `latest.json` is expected to be cacheable for 60 seconds, and the
# referenced `.pmtiles` objects are expected to be immutable year-cache objects.
# Leave mode unset to keep using the built-in local /tiles/* manifests copied into dist.
VITE_PARCELS_MANIFEST_URL=https://tiles.example.com/tiles/parcels-draw-v1/latest.json
VITE_ENVIRONMENTAL_FLOOD_MANIFEST_URL=https://tiles.example.com/tiles/environmental-flood/latest.json
VITE_ENVIRONMENTAL_HYDRO_BASINS_MANIFEST_URL=https://tiles.example.com/tiles/environmental-hydro-basins/latest.json

# Optional basemap overrides.
# VITE_SATELLITE_BASEMAP_URL=
# VITE_SATELLITE_BASEMAP_URLS=
# VITE_SATELLITE_MAX_ZOOM=
