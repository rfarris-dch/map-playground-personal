{
  "name": "map-platform",
  "private": true,
  "packageManager": "bun@1.2.22",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel --filter=@map-migration/api --filter=@map-migration/web",
    "dev:all": "turbo run dev --parallel",
    "dev:api": "bun run --cwd apps/api dev",
    "dev:web": "bun run --cwd apps/web dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "biome lint .",
    "ultracite:check": "ultracite check",
    "ultracite:fix": "ultracite fix",
    "typecheck": "turbo run typecheck",
    "lint:turbo": "turbo run lint",
    "format": "biome check --write .",
    "format:check": "biome check .",
    "check": "biome check .",
    "sync:hyperscale": "bash ./scripts/refresh-hyperscale.sh",
    "init:parcels-schema": "bash ./scripts/init-parcels-schema.sh",
    "load:parcels-canonical": "bash ./scripts/load-parcels-canonical.sh",
    "tiles:build:parcels": "bash ./scripts/build-parcels-draw-pmtiles.sh",
    "sync:parcels": "bash ./scripts/refresh-parcels.sh",
    "tiles:publish:parcels": "bun run ./scripts/publish-parcels-manifest.ts --dataset=parcels-draw-v1",
    "tiles:rollback:parcels": "bun run ./scripts/rollback-parcels-manifest.ts --dataset=parcels-draw-v1",
    "dev:pipeline-monitor": "bun run --cwd apps/pipeline-monitor dev",
    "build:pipeline-monitor": "bun run --cwd apps/pipeline-monitor build",
    "typecheck:pipeline-monitor": "bun run --cwd apps/pipeline-monitor typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "turbo": "^2.5.6",
    "typescript": "^5.7.3",
    "ultracite": "7.2.4"
  }
}
