{
  "name": "map-platform",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:prepare:packages": "turbo run build --filter=@map-migration/core-runtime --filter=@map-migration/geo-kernel --filter=@map-migration/geo-sql --filter=@map-migration/geo-tiles --filter=@map-migration/http-contracts --filter=@map-migration/map-engine --filter=@map-migration/map-layer-catalog --filter=@map-migration/map-style --filter=@map-migration/ops",
    "dev:prepare": "bun run dev:prepare:packages",
    "dev:prepare:all": "bun run dev:prepare:packages",
    "dev": "bash ./scripts/stop-api-dev-port.sh api web && bun run dev:prepare && turbo run dev --filter=@map-migration/api --filter=@map-migration/web",
    "dev:all": "MAP_EFFECT_DEVTOOLS=1 bash ./scripts/stop-api-dev-port.sh all && bun run dev:prepare:all && MAP_EFFECT_DEVTOOLS=1 turbo run dev --concurrency=20 --filter=@map-migration/api... --filter=@map-migration/web... --filter=@map-migration/pipeline-monitor...",
    "dev:api": "bash ./scripts/stop-api-dev-port.sh api && turbo run dev --filter=@map-migration/api",
    "dev:api:sync-worker": "bun run --cwd apps/api dev:sync-worker",
    "dev:web": "turbo run dev --filter=@map-migration/web",
    "build": "turbo run build",
    "build:deploy:app": "TURBO_DAEMON=false turbo run build --filter=@map-migration/api... --filter=@map-migration/web...",
    "build:affected": "turbo run build --affected",
    "test": "turbo run test",
    "test:affected": "turbo run test --affected",
    "lint": "turbo run lint",
    "lint:affected": "turbo run lint --affected",
    "lint:repo": "biome lint .",
    "ultracite:check": "ultracite check",
    "ultracite:fix": "ultracite fix",
    "typecheck": "turbo run typecheck",
    "typecheck:affected": "turbo run typecheck --affected",
    "lint:turbo": "turbo run lint",
    "format": "biome check --write .",
    "format:check": "biome check .",
    "check": "biome check .",
    "init:county-scores-schema": "bash ./scripts/init-county-scores-schema.sh",
    "init:source-registry-schema": "bash ./scripts/init-source-registry-schema.sh",
    "init:facility-provider-schema": "bash ./scripts/init-facility-provider-schema.sh",
    "publish:source-registry": "bun run ./scripts/publish-source-registry.ts",
    "sync:county-scores": "bash ./scripts/refresh-county-scores.sh",
    "sync:county-power": "bun run ./scripts/refresh-county-power.ts --step=sync",
    "sync:facility-providers": "bash ./scripts/refresh-facility-providers.sh",
    "sync:facilities": "bash ./scripts/refresh-facilities-fast.sh",
    "rollback:facilities": "bash ./scripts/rollback-facilities-manifest.sh",
    "init:market-source-schema": "bash ./scripts/init-market-source-schema.sh",
    "sync:market-source": "bash ./scripts/sync-market-source.sh",
    "init:market-canonical-schema": "bash ./scripts/init-market-canonical-schema.sh",
    "load:market-canonical": "bash ./scripts/load-market-canonical.sh",
    "init:market-boundaries-schema": "bash ./scripts/init-market-boundaries-schema.sh",
    "sync:market-boundaries": "bash ./scripts/refresh-market-boundaries.sh",
    "init:parcels-schema": "bash ./scripts/init-parcels-schema.sh",
    "tiles:install:planetiler": "bash ./scripts/install-planetiler.sh",
    "load:parcels-canonical": "bash ./scripts/load-parcels-canonical.sh",
    "tiles:refresh:parcels-tilesource": "sh -c 'bash ./scripts/refresh-parcel-tilesource.sh ${RUN_ID:-}'",
    "tiles:build:parcels": "sh -c 'bash ./scripts/refresh-parcel-tilesource.sh ${RUN_ID:-} && bash ./scripts/build-parcels-draw-pmtiles.sh ${RUN_ID:-}'",
    "sync:parcels": "bun run ./scripts/run-pipeline.ts --dataset=parcels",
    "tiles:publish:parcels": "bun run ./scripts/publish-parcels-manifest.ts --dataset=parcels-draw-v1",
    "tiles:publish:s3": "bun run ./scripts/publish-tiles-to-s3.ts",
    "tiles:rollback:parcels": "bun run ./scripts/rollback-parcels-manifest.ts --dataset=parcels-draw-v1",
    "sync:environmental-flood": "bun run ./scripts/run-pipeline.ts --dataset=flood",
    "sync:environmental-hydro-basins": "bun run ./scripts/run-pipeline.ts --dataset=hydro-basins",
    "tiles:refresh:environmental-flood-tilesource": "sh -c 'bash ./scripts/refresh-environmental-flood-tilesources.sh ${RUN_ID:-} all'",
    "tiles:build:environmental-flood": "sh -c 'bash ./scripts/refresh-environmental-flood-tilesources.sh ${RUN_ID:-} all && bash ./scripts/build-environmental-flood-pmtiles.sh ${RUN_ID:-}'",
    "tiles:publish:environmental-flood": "sh -c 'bun run ./scripts/publish-parcels-manifest.ts --dataset=environmental-flood --run-id=${RUN_ID:-sample}'",
    "tiles:rollback:environmental-flood": "bun run ./scripts/rollback-parcels-manifest.ts --dataset=environmental-flood",
    "tiles:refresh:environmental-hydro-basins-tilesource": "sh -c 'bash ./scripts/refresh-environmental-hydro-tilesource.sh ${RUN_ID:-}'",
    "tiles:build:environmental-hydro-basins": "sh -c 'bash ./scripts/refresh-environmental-hydro-tilesource.sh ${RUN_ID:-} && bash ./scripts/build-environmental-hydro-basins-pmtiles.sh ${RUN_ID:-}'",
    "tiles:publish:environmental-hydro-basins": "sh -c 'bun run ./scripts/publish-parcels-manifest.ts --dataset=environmental-hydro-basins --run-id=${RUN_ID:-sample}'",
    "tiles:rollback:environmental-hydro-basins": "bun run ./scripts/rollback-parcels-manifest.ts --dataset=environmental-hydro-basins",
    "tiles:serve:martin": "martin --config ./config/martin/martin.yml",
    "dev:pipeline-monitor": "turbo run dev --filter=@map-migration/pipeline-monitor",
    "build:pipeline-monitor": "turbo run build --filter=@map-migration/pipeline-monitor",
    "typecheck:pipeline-monitor": "turbo run typecheck --filter=@map-migration/pipeline-monitor",
    "start:api:prod": "bun run --cwd apps/api start:prod",
    "validate:api:health": "bash ./scripts/validate-api-health.sh",
    "validate:facilities:edge": "bash ./scripts/validate-facilities-edge.sh",
    "validate:tile-delivery": "bun run ./scripts/validate-tile-delivery.ts"
  },
  "devDependencies": {
    "@map-migration/geo-tiles": "workspace:*",
    "@map-migration/ops": "workspace:*",
    "@biomejs/biome": "^2.4.8",
    "bun-types": "^1.3.11",
    "tsc-alias": "^1.8.16",
    "turbo": "^2.8.20",
    "typescript": "^6.0.2",
    "ultracite": "7.3.2"
  }
}
