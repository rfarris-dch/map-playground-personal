{
  "name": "@map-migration/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "MAP_FORCE_KILL_PORT_BEFORE_START=1 bun --env-file .env --watch src/index.ts",
    "dev:sync-worker": "bun --env-file .env --watch src/sync-worker.ts",
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "test": "bun test",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@effect/platform": "^0.94.5",
    "@effect/platform-bun": "^0.87.1",
    "@hono/node-server": "^1.13.8",
    "@map-migration/contracts": "workspace:*",
    "@map-migration/geo-sql": "workspace:*",
    "@map-migration/ops": "workspace:*",
    "effect": "^3.19.19",
    "hono": "^4.6.10"
  },
  "devDependencies": {
    "@types/node": "^22.10.2"
  }
}
