{
  "name": "@map-migration/geo-kernel",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/geometry.js",
  "types": "dist/geometry.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json --resolve-full-paths --resolve-full-extension .js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "echo 'no tests yet'",
    "ci:check": "bun run typecheck && bun run test",
    "lint": "biome check .",
    "dev": "bun run build && (tsc -w -p tsconfig.json & tsc-alias -w -p tsconfig.json --resolve-full-paths --resolve-full-extension .js)"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "exports": {
    "./geometry": {
      "types": "./dist/geometry.d.ts",
      "default": "./dist/geometry.js"
    },
    "./facility-perspective": {
      "types": "./dist/facility-perspective.d.ts",
      "default": "./dist/facility-perspective.js"
    },
    "./commissioned-semantic": {
      "types": "./dist/commissioned-semantic.d.ts",
      "default": "./dist/commissioned-semantic.js"
    },
    "./warning": {
      "types": "./dist/warning.d.ts",
      "default": "./dist/warning.js"
    },
    "./area-of-interest": {
      "types": "./dist/area-of-interest.d.ts",
      "default": "./dist/area-of-interest.js"
    },
    "./area-of-interest-policy": {
      "types": "./dist/area-of-interest-policy.d.ts",
      "default": "./dist/area-of-interest-policy.js"
    }
  },
  "files": [
    "dist"
  ]
}
