{
  "name": "@map-migration/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "MAP_FORCE_KILL_PORT_BEFORE_START=1 nodemon --delay 300ms --watch src --watch ../../packages/contracts/dist --watch ../../packages/core-runtime/dist --watch ../../packages/geo-sql/dist --watch ../../packages/ops/dist --ext ts,js,json --signal SIGTERM --exec \"bun --env-file .env src/index.ts\"",
    "dev:sync-worker": "nodemon --delay 300ms --watch src --watch ../../packages/contracts/dist --watch ../../packages/core-runtime/dist --watch ../../packages/geo-sql/dist --watch ../../packages/ops/dist --ext ts,js,json --signal SIGTERM --exec \"bun --env-file .env src/sync-worker.ts\"",
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json && bash ../../scripts/normalize-api-dist-imports.sh dist",
    "start:prod": "NODE_ENV=production bun dist/index.js",
    "test": "bun test",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@effect/experimental": "^0.58.0",
    "@effect/platform": "^0.94.5",
    "@effect/platform-bun": "^0.87.1",
    "@hono/node-server": "^1.13.8",
    "@map-migration/contracts": "workspace:*",
    "@map-migration/core-runtime": "workspace:*",
    "@map-migration/geo-sql": "workspace:*",
    "@map-migration/ops": "workspace:*",
    "effect": "^3.19.19",
    "hono": "^4.6.10"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "nodemon": "^3.1.14"
  }
}
